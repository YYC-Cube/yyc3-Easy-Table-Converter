{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "target": "ES2022",
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "useUnknownInCatchVariables": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@/YYC_原油/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/ui/**/*.tsx",
    "components/table/**/*.tsx",
    "components/ai/**/*.tsx",
    "components/color-tools/**/*.tsx",
    "components/image-editor/**/*.tsx",
    "components/progress/**/*.tsx",
    "components/BatchProcessorPanel.tsx",
    "components/ConversionFlow.tsx",
    "components/DataLoader.tsx",
    "components/DataOptimizer.tsx",
    "components/DataPreview.tsx",
    "components/ErrorBoundary.tsx",
    "components/ExportDialog.tsx",
    "components/Header.tsx",
    "components/HistoryPanel.tsx",
    "components/HowToUse.tsx",
    "components/InputPanel.tsx",
    "components/OutputPanel.tsx",
    "components/PresetPanel.tsx",
    "components/StepBar.tsx",
    "components/TableView.tsx",
    "components/ToolCard.tsx",
    "components/VirtualTable.tsx",
    "components/theme-provider.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "lib/converters/**/*.ts",
    "lib/utils/**/*.ts",
    "lib/services/**/*.ts",
    "lib/auth/**/*.ts",
    "lib/db/**/*.ts",
    "lib/i18n/**/*.ts",
    "lib/table/parsers.ts",
    "lib/table/serializers.ts",
    "lib/table/formatTableData.ts",
    "lib/table/constants.ts",
    "lib/types/**/*.ts",
    "lib/exportUtils.ts",
    "lib/formatGenerators.ts",
    "lib/swagger.ts",
    "lib/types.ts",
    "lib/utils.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".next",
    "coverage",
    "services",
    "docs",
    "scripts",
    "e2e",
    "app/industries",
    "app/__tests__",
    "app/utils/workers",
    "components/industries",
    "components/text-tools",
    "components/security-tools",
    "components/PerformanceTester.tsx",
    "components/PerformanceOptimizer.tsx",
    "components/PerformanceIndicator.tsx",
    "components/ProgressIndicator.tsx",
    "components/TableIntegrator.tsx",
    "components/TableDataVisualizer.tsx",
    "components/VirtualizedTable.tsx",
    "components/ResponsiveUtils.tsx",
    "components/ThemeStyles.tsx",
    "components/PreviewPanel.tsx",
    "components/LoadingState.tsx",
    "components/FormComponents.tsx",
    "lib/table/arrowProcessor.ts",
    "lib/constants/converters.ts",
    "lib/wasm",
    "__tests__"
  ],
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
