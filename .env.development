# YYC³ Easy Table Converter 环境配置
# 开发环境

# 应用配置
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development

# API 配置
NEXT_PUBLIC_API_BASE_URL=http://localhost:3737/api

# 数据库配置
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=yyc3_web
DATABASE_PASSWORD=yyc3_web_2026
DATABASE_NAME=yyc3_web

# JWT 配置
JWT_SECRET=yyc3_jwt_secret_key_2026_dev
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# NextAuth 配置
NEXTAUTH_URL=http://localhost:3737
NEXTAUTH_SECRET=yyc3_nextauth_secret_key_2026_dev

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379

# AI 服务配置
AI_API_KEY_OPENAI=test_openai_api_key_for_development
LOCAL_MODEL_ENDPOINT=http://localhost:8080/v1
LOCAL_MODEL_API_KEY=local_dev_key

# 缓存配置
AI_CACHE_TTL=300000
AI_LOG_LEVEL=debug
