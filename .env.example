# AI服务配置
# 以下是AI服务提供商的API密钥配置示例
# 在实际开发中，请创建.env.development文件并填入实际密钥

# OpenAI API配置
AI_API_KEY_OPENAI=your_openai_api_key_here

# Azure OpenAI配置（可选）
AI_API_KEY_AZURE_OPENAI=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name

# Claude API配置（可选）
AI_API_KEY_CLAUDE=your_claude_api_key_here

# Gemini API配置（可选）
AI_API_KEY_GEMINI=your_gemini_api_key_here

# 本地模型配置（可选）
LOCAL_MODEL_ENDPOINT=http://localhost:8080/v1
LOCAL_MODEL_API_KEY=local_model_key

# 项目环境配置
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development

# 应用配置
NEXT_PUBLIC_APP_NAME="YYC³ Easy Table Converter"
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_APP_DESCRIPTION="企业级表格转换工具"

# 开发服务器配置
NEXT_PUBLIC_API_BASE_URL=http://localhost:3737/api

# 缓存配置（毫秒）
AI_CACHE_TTL=3600000

# 日志级别（debug, info, warn, error）
AI_LOG_LEVEL=info

# 默认模型配置
AI_DEFAULT_MODEL=gpt-4

# 注意：敏感信息不要提交到版本控制系统
# 请将实际使用的.env文件添加到.gitignore中
