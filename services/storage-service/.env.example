# 基础配置
PORT=3300
NODE_ENV=development

# MongoDB配置
MONGO_URI=mongodb://localhost:27017/storage-service

# 存储服务配置
DEFAULT_STORAGE_TYPE=local # 可选: local, s3, gcs
UPLOAD_DIR=./uploads

# AWS S3 配置（可选）
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=yyc-table-converter
S3_ENDPOINT=https://s3.amazonaws.com

# Google Cloud Storage 配置（可选）
GCS_BUCKET_NAME=yyc-table-converter
# GCS_CREDENTIALS 是一个JSON字符串，包含完整的服务账号凭证
GCS_CREDENTIALS='{"type":"service_account","project_id":"your-project-id",...}'

# 日志配置
LOG_LEVEL=info

# 安全配置
MAX_FILE_SIZE=50mb
ALLOWED_FILE_TYPES=csv,xlsx,xls,pdf,json
