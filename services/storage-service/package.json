{
  "name": "storage-service",
  "version": "2.0.0",
  "description": "YYC³ Easy Table Converter 存储服务 - 支持多存储后端(本地/S3/GCS)",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc && npm run copy-files",
    "copy-files": "mkdir -p dist/config && cp -r config/* dist/config/ 2>/dev/null || true && cp .env.example dist/",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write '**/*.{ts,tsx,js,json,md}'",
    "release": "bash scripts/release.sh",
    "prebuild": "rm -rf dist",
    "postinstall": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.2",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "aws-sdk": "^2.1464.0",
    "uuid": "^9.0.1",
    "@google-cloud/storage": "^7.5.0",
    "zod": "^3.22.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.14",
    "@types/morgan": "^1.9.5",
    "@types/multer": "^1.4.8",
    "@types/node": "^20.5.7",
    "@types/uuid": "^9.0.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2",
    "jest": "^29.6.4",
    "@types/jest": "^29.5.4",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.1"
  },
  "author": "YYC",
  "license": "MIT"
}